# ==============================================================================
# S.A.P.I. - INFRAESTRUCTURA DE PERSISTENCIA HÍBRIDA (ENTREGA FINAL 2026)
# ==============================================================================

# Entorno de Desarrollo Local (Docker Compose)
POSTGRES_USER=sapi
POSTGRES_PASSWORD=sapi_secret
POSTGRES_DB=sapi_db
DATABASE_URL=postgresql://sapi:sapi_secret@db-postgis:5432/sapi_db
DATABASE_URL_DIRECT=postgresql://sapi:sapi_secret@db-postgis:5432/sapi_db

# ------------------------------------------------------------------------------
# Producción Streamlit Cloud — Connection Pooler (puerto 6543)
# NOTA: sslmode=require es obligatorio para validación del backend cloud.
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres.PROJECT:PASS@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# ------------------------------------------------------------------------------
# Producción Analytics Backend — Conexión directa batch (puerto 5432)
# ------------------------------------------------------------------------------
# DATABASE_URL_DIRECT=postgresql://postgres.PROJECT:PASS@db.PROJECT.supabase.co:5432/postgres?sslmode=require

# Credenciales de Telemetría Externa
NASA_FIRMS_API_KEY=your_nasa_firms_key
DMC_API_BASE_URL=https://climatologia.meteochile.gob.cl
CONAF_DATA_URL=https://www.conaf.cl

DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_PREDICTIONS_DIR=data/predictions
MODELS_DIR=models

CACHE_CONTINGENCY_DAYS=7
GRID_CELL_SIZE_KM=1.0
GRID_MAX_CELLS=50

STREAMLIT_SERVER_PORT=8501
